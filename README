        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🧠 KIND-TGPT</h1>
            <p>Advanced AI System by Karlfiner-Robotiken</p>
            <div>
                <span class="badge">🚀 GODMODE</span>
                <span class="badge">🤖 TGPT Powered</span>
