            📝 MIT License | 
            🧠 Karlfiner-Robotiken</p>
        </div>
    </div>
    
    <script>
        async function loadStats() {
            try {
                const res = await fetch('/api/stats');
                const stats = await res.json();
                document.getElementById('interactions').innerText = stats.total_interactions;
                document.getElementById('memory').innerText = stats.memory_size;
                document.getElementById('tgpt').innerText = stats.tgpt_available ? 'Active' : 'Fallback';
            } catch(e) {
                console.error('Stats error:', e);
            }
        }
        
        async function solve() {
            const problem = document.getElementById('problem').value;
            if (!problem.trim()) return;
            
            const responseDiv = document.getElementById('response');
            responseDiv.innerHTML = '🧠 KIND-TGPT is thinking...';
            
            try {
                const res = await fetch('/api/solve', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({problem: problem})
                });
                const data = await res.json();
                responseDiv.innerHTML = data.solution;
                loadStats();
                document.getElementById('problem').value = '';
            } catch(e) {
                responseDiv.innerHTML = '❌ Error connecting to KIND-TGPT';
            }
        }
        
        loadStats();
        setInterval(loadStats, 5000);
    </script>
</body>
</html>
"""

@app.route('/')
def dashboard():
    return render_template_string(DASHBOARD)

@app.route('/api/solve', methods=['POST'])
def api_solve():
    data = request.json
    problem = data.get('problem', '')
    solution = kind.solve(problem, source="web")
    return jsonify({"solution": solution})

@app.route('/api/stats')
def api_stats():
    return jsonify(kind.get_stats())

@app.route('/health')
def health():
    return jsonify({"status": "healthy", "version": CONFIG["VERSION"]})

if __name__ == "__main__":
    app.run(host='0.0.0.0', port=5000, debug=False)
EOF

# ============================================
# INSTALLATION SCRIPTS
# ============================================
cat > install.sh << 'EOF'
#!/bin/bash
# KIND-TGPT Installer for Karlfiner-Robotiken

GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🤖 Installing KIND-TGPT from Karlfiner-Robotiken...${NC}"

# Install dependencies
pip install flask flask-cors --quiet

# Create config directory
mkdir -p ~/.kind_tgpt

# Create command
cat > $PREFIX/bin/kind-tgpt << 'CMDEF'
#!/bin/bash
KIND_DIR="$HOME/kind-tgpt"

case "$1" in
    start)
        cd $KIND_DIR
        python3 src/kind_tgpt.py &
        sleep 2
        echo "✅ KIND-TGPT started on http://localhost:5000"
        echo "🌐 Open: http://localhost:5000"
        ;;
    stop)
        pkill -f "kind_tgpt.py"
        echo "✅ KIND-TGPT stopped"
        ;;
    status)
        curl -s http://localhost:5000/health 2>/dev/null && echo "✅ Running" || echo "❌ Stopped"
        ;;
    stats)
        curl -s http://localhost:5000/api/stats | python3 -m json.tool
        ;;
    cli)
        cd $KIND_DIR
        python3 -c "
from src.kind_tgpt import kind
print('🧠 KIND-TGPT CLI (type exit to quit)\n' + '='*50)
while True:
    prob = input('\n💬 You: ')
    if prob.lower() in ['exit', 'quit']:
        print('👋 Goodbye!')
        break
    print(f'\n🤖 KIND-TGPT: {kind.solve(prob, source=\"cli\")}\n' + '='*50)
"
        ;;
    *)
        echo "KIND-TGPT by Karlfiner-Robotiken"
        echo ""
        echo "Commands:"
        echo "  start  - Start web server"
        echo "  cli    - CLI mode"
        echo "  stop   - Stop server"
        echo "  status - Check status"
        echo "  stats  - Show statistics"
        echo ""
        ;;
esac
CMDEF
chmod +x $PREFIX/bin/kind-tgpt

echo -e "${GREEN}✅ KIND-TGPT installed successfully!${NC}"
echo -e "${BLUE}Run 'kind-tgpt start' to begin${NC}"
EOF
chmod +x install.sh

